{
  "name": "ncm-am-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --test-scheduled",
    "typecheck": "./node_modules/.bin/tsc --noEmit",
    "typecheck:ui": "./node_modules/.bin/tsc -p web/tsconfig.json --noEmit",
    "build:ui": "vite build",
    "build": "npm run typecheck && npm run typecheck:ui && npm run build:ui",
    "deploy": "npm run build && wrangler deploy",
    "tail": "wrangler tail"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@cloudflare/workers-types": "^4.20260507.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.5",
    "wrangler": "^4.88.0"
  }
}
